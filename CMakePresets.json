{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ninja",
      "cacheVariables": {
        "TACHYON_ENABLE_COMPILER_CACHE": "ON",
        "TACHYON_ENABLE_PCH": "ON",
        "CMAKE_POLICY_DEFAULT_CMP0141": "NEW",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "$<$<CONFIG:Debug,RelWithDebInfo>:Embedded>",
        "FETCHCONTENT_BASE_DIR": "${sourceDir}/.cache/fetchcontent/ninja-msvc-x64"
      }
    },
    {
      "name": "relwithdebinfo-unity",
      "inherits": "relwithdebinfo",
      "description": "RelWithDebInfo with Unity Build (Jumbo)",
      "cacheVariables": {
        "TACHYON_UNITY_BUILD": "ON"
      }
    },
    {
      "name": "relwithdebinfo-lld",
      "inherits": "relwithdebinfo",
      "description": "RelWithDebInfo with lld-link linker",
      "cacheVariables": {
        "CMAKE_LINKER_TYPE": "LLD"
      }
    },
    {
      "name": "relwithdebinfo-fast",
      "inherits": "relwithdebinfo",
      "description": "Fast build: Unity + lld-link",
      "cacheVariables": {
        "TACHYON_UNITY_BUILD": "ON",
        "CMAKE_LINKER_TYPE": "LLD"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "description": "Debug build with full symbols",
      "cacheVariables": {
        "TACHYON_ENABLE_ASAN": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "description": "Release build with optimizations",
      "cacheVariables": {
        "TACHYON_ENABLE_ASAN": "OFF",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "inherits": "base",
      "description": "Release with debug info - recommended for development",
      "cacheVariables": {
        "TACHYON_ENABLE_ASAN": "OFF",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "asan",
      "inherits": "base",
      "description": "AddressSanitizer preset for memory and lifetime bugs",
      "cacheVariables": {
        "TACHYON_ENABLE_ASAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug",
      "targets": [
        "TachyonCore",
        "tachyon",
        "TachyonTests"
      ]
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "TachyonCore",
        "tachyon",
        "TachyonTests"
      ]
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo",
      "configuration": "RelWithDebInfo",
      "targets": [
        "TachyonCore",
        "tachyon",
        "TachyonTests"
      ]
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "configuration": "RelWithDebInfo",
      "targets": [
        "TachyonCore",
        "TachyonTests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo",
      "configuration": "RelWithDebInfo"
    }
  ]
}
