{
  "version": "1.0",
  "spec_version": "1.0.0",
  "project": { "id": "demo", "name": "Text with Background" },
  "compositions": [
    {
      "id": "main",
      "width": 1920, "height": 1080, "duration": 5.0, "fps": 60,
      "components": [
        {
          "id": "bg_aura_modern",
          "layers": [
            {
              "id": "aura_base", "type": "procedural",
              "procedural": {
                "kind": "aura", "speed": "{{speed}}", "amplitude": "{{intensity}}",
                "frequency": 1.5, "color_a": "{{color_primary}}", "color_b": "{{color_secondary}}"
              }
            }
          ]
        }
      ],
      "layers": [
        {
          "id": "overlay_text", "type": "text", "text_content": "TACHYON",
          "font_id": "main_font", "fill_color": "#FFFFFF", "font_size": 200,
          "alignment": "center",
          "transform": { "position": [960, 540] }
        }
      ],
      "component_instances": [
        {
          "component_id": "bg_aura_modern", "instance_id": "bg",
          "param_values": { 
            "color_primary": "#110022", "color_secondary": "#5500AA", 
            "speed": "0.3", "intensity": "0.7" 
          }
        }
      ]
    }
  ]
}
