{
  "version": "1.0",
  "spec_version": "1.0.0",
  "project": { "id": "gallery", "name": "Gallery" },
  "compositions": [
    {
      "id": "main",
      "width": 1920, "height": 1080, "duration": 5.0,
      "fps": 60,
      "frame_rate": { "numerator": 60, "denominator": 1 },
      "components": [
        {
          "id": "bg_liquid_deep",
          "layers": [
            {
              "id": "liquid_base", "type": "procedural",
              "procedural": {
                "kind": "noise", "speed": 0.2, "amplitude": 0.8, "scale": 2.0,
                "color_a": "#000000", "color_b": "{{accent_color}}"
              }
            }
          ]
        }
      ],
      "component_instances": [
        {
          "component_id": "bg_liquid_deep", "instance_id": "liquid",
          "param_values": { "accent_color": "#1A1A2E" }
        }
      ]
    }
  ]
}
