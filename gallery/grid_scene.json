{
  "version": "1.0",
  "spec_version": "1.0.0",
  "project": { "id": "gallery", "name": "Gallery" },
  "compositions": [
    {
      "id": "main",
      "width": 1920, "height": 1080, "duration": 5.0,
      "fps": 60,
      "frame_rate": { "numerator": 60, "denominator": 1 },
      "components": [
        {
          "id": "bg_grid_tech",
          "layers": [
            {
              "id": "grid_base", "type": "procedural",
              "procedural": {
                "kind": "grid", "spacing": 40.0, "border_width": 1.0,
                "border_color": "{{grid_color}}", "color_a": [0,0,0,0]
              }
            }
          ]
        }
      ],
      "component_instances": [
        {
          "component_id": "bg_grid_tech", "instance_id": "grid",
          "param_values": { "grid_color": "#3366FF" }
        }
      ]
    }
  ]
}
