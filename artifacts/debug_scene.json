{
  "version": "1.0",
  "project": {
    "id": "debug_render",
    "name": "Debug Render"
  },
  "assets": [
    {
      "id": "bg_img",
      "type": "image",
      "source": "bg.png"
    }
  ],
  "compositions": [
    {
      "id": "main_comp",
      "width": 1920,
      "height": 1080,
      "duration": 2.0,
      "fps": 30,
      "layers": [
        {
          "id": "bg_layer",
          "type": "image",
          "name": "bg_img",
          "transform": {
            "position": [960, 540],
            "scale": [1, 1]
          }
        },
        {
          "id": "debug_text",
          "type": "text",
          "text_content": "DEBUG TEST",
          "font_id": "main_font",
          "font_size": 200,
          "fill_color": [255, 0, 0, 255],
          "transform": {
            "position": [960, 540]
          }
        }
      ]
    }
  ]
}
