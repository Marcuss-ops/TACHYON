{
  "version": "1.0",
  "project": {
    "id": "final_text_demo",
    "name": "Tachyon Kinetic Text"
  },
  "font_manifest": "fonts.json",
  "assets": [
    {
      "id": "bg_asset",
      "type": "image",
      "source": "bg.png"
    }
  ],
  "compositions": [
    {
      "id": "main_comp",
      "width": 1920,
      "height": 1080,
      "duration": 5.0,
      "fps": 30,
      "layers": [
        {
          "id": "bg_asset",
          "type": "image",
          "name": "bg_asset",
          "transform": {
            "position": [960, 540],
            "scale": [1, 1]
          }
        },
        {
          "id": "main_text",
          "type": "text",
          "text_content": "TACHYON: CINEMATIC TEXT",
          "font_id": "main_font",
          "font_size": 120,
          "fill_color": [255, 255, 255, 255],
          "transform": {
            "position": [960, 540]
          },
          "text_animators": [
            {
              "name": "Typewriter",
              "selector": { 
                "type": "range", 
                "stagger_delay": 0.05,
                "start": 0,
                "end": 100
              },
              "properties": { 
                "opacity_value": 0.0,
                "scale_value": 0.5
              }
            }
          ]
        }
      ]
    }
  ]
}
