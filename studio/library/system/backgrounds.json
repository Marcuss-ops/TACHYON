{
  "schema": "tachyon.component_library/1.0",
  "id": "modern_backgrounds",
  "name": "Modern Background Library",
  "components": [
    {
      "id": "bg_aura_modern",
      "name": "Modern Aura Background",
      "description": "Fluid animated aura background with two customizable colors.",
      "params": [
        { "name": "color_primary", "type": "color", "default": "#FF3366" },
        { "name": "color_secondary", "type": "color", "default": "#3366FF" },
        { "name": "speed", "type": "double", "default": 0.5 },
        { "name": "intensity", "type": "double", "default": 1.0 }
      ],
      "layers": [
        {
          "id": "aura_base",
          "type": "procedural",
          "procedural": {
            "kind": "aura",
            "speed": "{{speed}}",
            "amplitude": "{{intensity}}",
            "frequency": 1.5,
            "color_a": "{{color_primary}}",
            "color_b": "{{color_secondary}}"
          }
        }
      ]
    },
    {
      "id": "bg_liquid_deep",
      "name": "Liquid Deep Background",
      "description": "Slow, dark fluid movement for premium look.",
      "params": [
        { "name": "accent_color", "type": "color", "default": "#1A1A2E" }
      ],
      "layers": [
        {
          "id": "liquid_base",
          "type": "procedural",
          "procedural": {
            "kind": "noise",
            "speed": 0.2,
            "amplitude": 0.8,
            "scale": 2.0,
            "color_a": "#000000",
            "color_b": "{{accent_color}}"
          }
        }
      ]
    },
    {
      "id": "bg_noise",
      "name": "Classic Noise",
      "params": [
        { "name": "frequency", "type": "double", "default": 1.0 },
        { "name": "amplitude", "type": "double", "default": 1.0 },
        { "name": "seed", "type": "int", "default": 0 }
      ],
      "layers": [
        {
          "id": "noise_base",
          "type": "procedural",
          "procedural": {
            "kind": "noise",
            "frequency": "{{frequency}}",
            "amplitude": "{{amplitude}}",
            "seed": "{{seed}}",
            "color_a": "#000000",
            "color_b": "#FFFFFF"
          }
        }
      ]
    },
    {
      "id": "bg_gradient",
      "name": "Linear Gradient",
      "params": [
        { "name": "color_a", "type": "color", "default": "#000000" },
        { "name": "color_b", "type": "color", "default": "#FFFFFF" },
        { "name": "angle", "type": "double", "default": 45.0 }
      ],
      "layers": [
        {
          "id": "grad_base",
          "type": "solid",
          "gradient_fill": {
            "type": "linear",
            "angle": "{{angle}}",
            "stops": [
              { "offset": 0.0, "color": "{{color_a}}" },
              { "offset": 1.0, "color": "{{color_b}}" }
            ]
          }
        }
      ]
    },
    {
      "id": "bg_waves",
      "name": "Animated Waves",
      "params": [
        { "name": "frequency", "type": "double", "default": 2.0 },
        { "name": "amplitude", "type": "double", "default": 0.5 },
        { "name": "speed", "type": "double", "default": 1.0 }
      ],
      "layers": [
        {
          "id": "waves_base",
          "type": "procedural",
          "procedural": {
            "kind": "waves",
            "frequency": "{{frequency}}",
            "amplitude": "{{amplitude}}",
            "speed": "{{speed}}"
          }
        }
      ]
    },
    {
      "id": "bg_grid",
      "name": "Procedural Grid",
      "params": [
        { "name": "spacing", "type": "double", "default": 50.0 },
        { "name": "border", "type": "double", "default": 1.0 },
        { "name": "shape", "type": "string", "default": "square" }
      ],
      "layers": [
        {
          "id": "grid_base",
          "type": "procedural",
          "procedural": {
            "kind": "grid",
            "spacing": "{{spacing}}",
            "border_width": "{{border}}",
            "shape": "{{shape}}"
          }
        }
      ]
    },
    {
      "id": "bg_stripes",
      "name": "Moving Stripes",
      "params": [
        { "name": "angle", "type": "double", "default": 0.0 },
        { "name": "speed", "type": "double", "default": 0.5 }
      ],
      "layers": [
        {
          "id": "stripes_base",
          "type": "procedural",
          "procedural": {
            "kind": "stripes",
            "angle": "{{angle}}",
            "speed": "{{speed}}"
          }
        }
      ]
    },
    {
      "id": "bg_stars",
      "name": "Starfield",
      "params": [
        { "name": "density", "type": "double", "default": 1.0 },
        { "name": "speed", "type": "double", "default": 0.1 }
      ],
      "layers": [
        {
          "id": "stars_base",
          "type": "procedural",
          "procedural": {
            "kind": "stars",
            "frequency": "{{density}}",
            "speed": "{{speed}}"
          }
        }
      ]
    }
  ]
}
