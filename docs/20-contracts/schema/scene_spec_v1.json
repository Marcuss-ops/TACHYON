{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TACHYON Scene Specification v1.0.0",
  "type": "object",
  "required": ["version", "project", "compositions"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "SemVer version of the scene spec."
    },
    "project": {
      "type": "object",
      "required": ["name", "authoring_tool"],
      "properties": {
        "name": { "type": "string" },
        "authoring_tool": { "type": "string" },
        "root_seed": { "type": "integer", "default": 0 }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["image", "video", "audio", "sequence"] },
          "path": { "type": "string" },
          "alpha_mode": { "enum": ["straight", "premultiplied"], "default": "straight" }
        }
      }
    },
    "compositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "width", "height", "fps", "duration", "layers"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "fps": { "type": "number", "minimum": 0.001 },
          "duration": { "type": "number", "minimum": 0 },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "name"],
              "properties": {
                "id": { "type": "string" },
                "type": { "enum": ["solid", "image", "comp", "text", "null", "camera", "light"] },
                "name": { "type": "string" },
                "start_time": { "type": "number", "default": 0 },
                "in_point": { "type": "number", "default": 0 },
                "out_point": { "type": "number" },
                "parent_id": { "type": "string" },
                "transform": {
                  "type": "object",
                  "properties": {
                    "position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                    "rotation": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                    "scale": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                    "anchor_point": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                    "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 }
                  }
                },
                "effects": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "type"],
                    "properties": {
                      "id": { "type": "string" },
                      "type": { "type": "string" },
                      "params": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
