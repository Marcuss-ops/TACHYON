{
  "job_id": "production_demo",
  "scene_ref": "production_demo.json",
  "composition_target": "main",
  "frame_range": { "start": 0, "end": 60 },
  "output": {
    "destination": { 
      "path": "demo_direct.mp4",
      "overwrite": true
    },
    "profile": {
      "name": "production_h264",
      "class": "ffmpeg_video",
      "container": "mp4",
      "alpha_mode": "ignored",
      "video": {
        "codec": "libx264",
        "pixel_format": "yuv420p",
        "rate_control_mode": "crf",
        "crf": 18.0
      },
      "buffering": {
        "strategy": "pipe"
      },
      "color": {
        "transfer": "bt709",
        "space": "bt709",
        "range": "limited"
      }
    }
  }
}
