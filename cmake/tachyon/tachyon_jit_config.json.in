{
  "compiler": "@CMAKE_CXX_COMPILER@",
  "cxx_standard": "@CMAKE_CXX_STANDARD@",
  "build_type": "@CMAKE_BUILD_TYPE@",
  "include_dirs": [
    "@CMAKE_CURRENT_SOURCE_DIR@/include",
    "@CMAKE_CURRENT_BINARY_DIR@/include"
  ],
  "library_dirs": [
    "@CMAKE_BINARY_DIR@/src",
    "@CMAKE_BINARY_DIR@/src/core",
    "@CMAKE_BINARY_DIR@/src/core/scene"
  ],
  "libraries": [
    "TachyonScene",
    "TachyonCore"
  ],
  "compile_definitions": [
    "TACHYON_ENABLE_MEDIA=@TACHYON_ENABLE_MEDIA@",
    "TACHYON_ENABLE_MIMALLOC=@TACHYON_ENABLE_MIMALLOC@",
    "TACHYON_ENABLE_HIGHWAY=@TACHYON_ENABLE_HIGHWAY@"
  ],
  "platform": "@CMAKE_SYSTEM_NAME@",
  "module_suffix": "@CMAKE_SHARED_MODULE_SUFFIX@",
  "abi_version": @TACHYON_JIT_ABI_VERSION@
}
