#pragma once

// Absolute path to Tachyon include directory
#define TACHYON_INCLUDE_DIR "@CMAKE_CURRENT_SOURCE_DIR@/include"

// Absolute path to third-party include directories

// Absolute path to the directory containing TachyonCore library
#define TACHYON_LIB_PATH "@CMAKE_BINARY_DIR@/src"

// Absolute path to vcvars64.bat, if CMake could discover a Visual Studio install.
#define TACHYON_VCVARS64_BAT "@TACHYON_VCVARS64_BAT@"

// Platform-specific library name for linking
#ifdef _WIN32
    #define TACHYON_CORE_LIB "TachyonCore.lib"
#else
    #define TACHYON_CORE_LIB "libTachyonCore.a"
#endif

// Feature Flags
#cmakedefine01 TACHYON_ENABLE_MEDIA
#cmakedefine01 TACHYON_ENABLE_HIGHWAY
#cmakedefine01 TACHYON_ENABLE_MIMALLOC

#define TACHYON_MEDIA_ENABLED TACHYON_ENABLE_MEDIA
#define TACHYON_SIMD_ENABLED TACHYON_ENABLE_HIGHWAY
#define TACHYON_MIMALLOC_ENABLED TACHYON_ENABLE_MIMALLOC

// Discovery Modes
#define TACHYON_FFMPEG_DISCOVERY_MODE "@TACHYON_FFMPEG_MODE@"

// Compiler Metadata
#define TACHYON_COMPILER_ID "@CMAKE_CXX_COMPILER_ID@"
#define TACHYON_COMPILER_VERSION "@CMAKE_CXX_COMPILER_VERSION@"
#define TACHYON_BUILD_TYPE "@CMAKE_BUILD_TYPE@"
